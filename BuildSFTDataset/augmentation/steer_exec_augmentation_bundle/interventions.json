{
  "schema_version": "1.1",
  "intended_use": "Augment interleaved <steer>/<exec> reasoning traces with explicit metacognitive interventions while keeping the resulting traces natural enough to use for supervised fine-tuning.",
  "high_level_goal": "Use a stronger teacher/editor model to generate only a short intervention window at a pair boundary, then either keep the original suffix or regenerate from the augmented prefix with the original model depending on how trajectory-changing the intervention is.",
  "mode_reference": {
    "insert": {
      "definition": "Add a short intervention window that preserves the existing reasoning trajectory.",
      "when_to_use": "Use when the intervention compresses context, restates, summarizes, or lightly clarifies without changing the plan.",
      "teacher_output": "Only the inserted intervention window of K new <steer>/<exec> pairs.",
      "suffix_policy": "keep_original_suffix",
      "key_prompt_requirement": "Provide the next original steer block so the teacher can write an intervention that naturally slots in before it."
    },
    "bridge": {
      "definition": "Add a short intervention window that slightly reframes or stress-tests the reasoning but tries to reconnect to the old path.",
      "when_to_use": "Use when the intervention may change local framing or confidence but should often be able to return to the original line of reasoning.",
      "teacher_output": "Only the inserted intervention window of K new <steer>/<exec> pairs.",
      "suffix_policy": "keep_if_next_steer_still_fits_else_regenerate",
      "key_prompt_requirement": "Provide the next original steer block as an anchor and ask the teacher to end in a way that makes that steer feel like a plausible next move."
    },
    "redirect": {
      "definition": "Add an intervention window that intentionally changes the reasoning trajectory.",
      "when_to_use": "Use when the intervention asks for backtracking, a new abstraction, a different strategy, a toy problem, or another move that should often replace the original continuation.",
      "teacher_output": "Only the inserted intervention window of K new <steer>/<exec> pairs.",
      "suffix_policy": "regenerate_suffix",
      "key_prompt_requirement": "Optionally provide the next original steer only as context for what the old trace would have done, not as a target to reconnect to."
    }
  },
  "sampling_defaults": {
    "one_intervention_per_trace": true,
    "default_dataset_mix": {
      "insert": 0.6,
      "bridge": 0.25,
      "redirect": 0.15
    },
    "sample_cut_points_at_pair_boundaries_only": true,
    "style_window_pairs": 2,
    "exec_token_limit": 512,
    "bridge_default_policy": "judge_whether_the_next_original_steer_still_fits",
    "first_new_steer_should_match_variant_exactly": true
  },
