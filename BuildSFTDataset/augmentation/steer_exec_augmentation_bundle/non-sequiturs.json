{
  "schema_version": "1.1",
  "intended_use": "Augment interleaved <steer>/<exec> reasoning traces with short insert-only non-sequitur detours whose inserted steer blocks can be masked during supervised fine-tuning.",
  "high_level_goal": "Use a teacher/editor model to splice in brief detours at random pair boundaries while keeping the original suffix intact, so the student model sees surprising local interventions without learning to emit the inserted steer text at training time.",
  "mode_reference": {
    "insert": {
      "definition": "Add a short intervention window that preserves the existing reasoning trajectory.",
      "when_to_use": "Use for local detours that should leave the original suffix intact.",
      "teacher_output": "Only the inserted intervention window of K new <steer>/<exec> pairs.",
      "suffix_policy": "keep_original_suffix",
      "key_prompt_requirement": "The inserted window must remain locally coherent without trying to reconnect to the next original steer."
    },
    "bridge": {
      "definition": "Unused in this catalog.",
      "when_to_use": "Not used for non-sequitur insert-only augmentation.",
      "teacher_output": "Not used.",
      "suffix_policy": "not_applicable",
      "key_prompt_requirement": "Not used."
    },
    "redirect": {
      "definition": "Unused in this catalog.",
      "when_to_use": "Not used for non-sequitur insert-only augmentation.",
      "teacher_output": "Not used.",
      "suffix_policy": "not_applicable",
      "key_prompt_requirement": "Not used."
    }
  },
