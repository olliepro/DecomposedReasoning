    "default_dataset_mix": {
      "insert": 1.0,
      "bridge": 0.0,
      "redirect": 0.0
    },
    "sample_cut_points_at_pair_boundaries_only": true,
    "style_window_pairs": 2,
    "exec_token_limit": 512,
    "steer_token_limit": 15,
    "bridge_default_policy": "not_used",
    "first_new_steer_should_match_variant_exactly": false
