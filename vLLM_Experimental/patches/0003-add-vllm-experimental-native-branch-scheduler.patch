+    def _vllm_exp_launch_branch_wave(
+        self, parent: Request, first_wave: bool
+    ) -> list[str]:
+        payload = self._vllm_exp_payload(parent)
+        assert payload is not None
+        parent_id = parent.request_id
+        pending = self._vllm_exp_pending_branch_plans[parent_id]
+        wave_size = min(
+            max(1, int(payload.get("native_branch_wave_size", 50))),
+            len(pending),
+        )
+        branch_budget = self._vllm_exp_branch_budgets[parent_id]
+        fork_tokens = self._vllm_exp_branch_fork_tokens[parent_id]
+        stop_token_ids = self._vllm_exp_branch_stop_token_ids[parent_id]
+        wave_plan = pending[:wave_size]
+        del pending[:wave_size]
+        child_ids: list[str] = []
+        for candidate_id, initial_script, followup_script in wave_plan:
+            child = self._vllm_exp_make_child(
+                parent,
+                candidate_id,
+                branch_budget,
+                initial_script,
+                followup_script,
+                stop_token_ids,
+            )
+            child.num_computed_tokens = fork_tokens
+            self.kv_cache_manager.fork_blocks(parent, child, fork_tokens)
+            self.requests[child.request_id] = child
+            self.waiting.add_request(child)
+            self._vllm_exp_child_to_parent[child.request_id] = parent_id
+            self._vllm_exp_branch_children[parent_id].append(child.request_id)
+            child_ids.append(child.request_id)
+        if not first_wave:
+            self._vllm_exp_log_event(
+                parent,
+                "branch_wave_start",
+                branch_budget=branch_budget,
+                candidate_count=len(child_ids),
+                child_ids=child_ids,
+                fork_tokens=fork_tokens,
+                pending_candidate_count=len(pending),
+                shared_blocks=fork_tokens // self.block_size,
+            )
+        return child_ids
+
+    def _vllm_exp_requested_branch_budget(
+        self, parent: Request, payload: dict[str, Any]
+    ) -> int:
+        if payload.get("mode") == "eps_on_policy_diverse":
+            return int(payload.get("max_steer_tokens", 30)) + 2
+        return int(payload.get("branch_max_tokens", 700))
+
+    def _vllm_exp_child_stop_token_ids(
+        self, parent: Request, payload: dict[str, Any]
+    ) -> list[int]:
+        if payload.get("mode") != "eps_on_policy_diverse":
+            return []
+        token_payload = payload.get("control_token_ids")
+        assert isinstance(token_payload, dict)
+        return [int(token_payload["steer_close"])]
+
+    def _vllm_exp_branch_plan(
+        self, parent: Request, payload: dict[str, Any]
+    ) -> list[tuple[int, list[int], list[int]]]:
+        mode = payload.get("mode")
+        if mode == "eps_on_policy_diverse":
+            candidate_count = int(payload.get("candidate_count", 50))
+            return [(candidate_id, [], []) for candidate_id in range(candidate_count)]
+        assert mode == "eps_off_policy_verbalized", mode
+        option_count = self._vllm_exp_option_count(parent, payload)
+        option_numbers = self._vllm_exp_option_numbers(parent, payload, option_count)
+        enum_script = self._vllm_exp_verbalized_script(
+            payload, "enumerate", option_count
+        )
+        return [
+            (
+                candidate_id,
+                enum_script,
+                self._vllm_exp_verbalized_script(payload, "continue", option_number),
+            )
+            for candidate_id, option_number in enumerate(option_numbers)
+        ]
+
+    def _vllm_exp_option_count(
+        self, parent: Request, payload: dict[str, Any]
+    ) -> int:
+        min_count = int(payload.get("off_policy_min_candidates", 3))
+        max_count = int(payload.get("off_policy_max_candidates", 10))
+        assert 1 <= min_count <= max_count <= 10
+        span = max_count - min_count + 1
+        if span == 1:
+            return min_count
+        raw = self._vllm_exp_hash_int(parent.request_id, "option_count")
+        return min_count + raw % span
+
+    def _vllm_exp_option_numbers(
+        self, parent: Request, payload: dict[str, Any], option_count: int
+    ) -> list[int]:
+        branch_fanout = int(payload.get("branch_fanout", 2))
+        assert 1 <= branch_fanout <= option_count
+        ranked = sorted(
+            range(1, option_count + 1),
+            key=lambda option: self._vllm_exp_hash_int(
+                parent.request_id, "option", option
+            ),
+        )
+        return ranked[:branch_fanout]
+
+    def _vllm_exp_hash_int(self, *parts: object) -> int:
+        raw = ":".join(str(part) for part in parts).encode("utf-8")
+        return int.from_bytes(hashlib.sha256(raw).digest()[:8], "big")
+
+    def _vllm_exp_verbalized_script(
+        self, payload: dict[str, Any], script_name: str, script_key: int
+    ) -> list[int]:
+        scripts = payload.get("verbalized_token_scripts")
+        assert isinstance(scripts, dict), "missing verbalized token scripts"
+        script_group = scripts.get(script_name)
+        assert isinstance(script_group, dict), f"missing {script_name} scripts"
+        token_ids = script_group.get(str(script_key))
+        assert isinstance(token_ids, list), f"missing {script_name} script {script_key}"
+        return [int(token_id) for token_id in token_ids]
+
+    def _vllm_exp_make_child(
+        self,
+        parent: Request,
+        candidate_id: int,
+        branch_budget: int,
+        initial_script: list[int],
+        followup_script: list[int],
+        stop_token_ids: list[int],
+    ) -> Request:
+        assert parent.sampling_params is not None
+        child_params = parent.sampling_params.clone()
+        self._vllm_exp_set_child_forced_scripts(
+            child_params,
+            parent,
+            initial_script,
+            followup_script,
+        )
+        child_params.max_tokens = (
+            parent.num_output_tokens
+            + len(initial_script)
+            + branch_budget
+            + len(followup_script)
+        )
+        self._vllm_exp_add_child_stop_tokens(child_params, stop_token_ids)
+        child_params.logprobs = max(child_params.logprobs or 0, 1)
+        child_params.n = 1
+        child_id = f"{parent.request_id}::vllm_exp_branch::{candidate_id}"
+        child = Request(
+            request_id=child_id,
+            prompt_token_ids=parent.prompt_token_ids,
+            sampling_params=child_params,
+            pooling_params=None,
+            client_index=parent.client_index,
+            arrival_time=time.time(),
+            prompt_embeds=parent.prompt_embeds,
+            prompt_is_token_ids=parent.prompt_is_token_ids,
+            mm_features=parent.mm_features,
+            lora_request=parent.lora_request,
+            cache_salt=parent.cache_salt,
+            priority=parent.priority,
+            trace_headers=parent.trace_headers,
+            block_hasher=parent._block_hasher,
+            resumable=False,
+        )
+        child.append_output_token_ids(list(parent.output_token_ids))
+        setattr(child, "_vllm_exp_hidden_branch", True)
+        setattr(child, "_vllm_exp_parent_id", parent.request_id)
+        setattr(child, "_vllm_exp_candidate_id", candidate_id)
+        return child
+
+    def _vllm_exp_add_child_stop_tokens(
+        self, child_params: Any, stop_token_ids: list[int]
+    ) -> None:
+        if not stop_token_ids:
+            return
+        existing = list(child_params.stop_token_ids or [])
+        for token_id in stop_token_ids:
+            if token_id not in existing:
+                existing.append(token_id)
+        child_params.stop_token_ids = existing
+        child_params._all_stop_token_ids.update(stop_token_ids)
+
+    def _vllm_exp_set_child_forced_scripts(
+        self,
+        child_params: Any,
+        parent: Request,
+        initial_script: list[int],
+        followup_script: list[int],
+    ) -> None:
+        extra_args = dict(child_params.extra_args or {})
+        payload = self._vllm_exp_payload(parent)
+        assert payload is not None
+        child_payload = dict(payload)
+        child_payload["forced_output_start_index"] = parent.num_output_tokens
+        child_payload["forced_output_token_ids"] = list(initial_script)
+        child_payload["forced_after_exec_close_token_ids"] = list(followup_script)
+        child_payload["forced_after_exec_close_trigger_after"] = (
+            parent.num_output_tokens + len(initial_script)
+        )
+        extra_args["vllm_experimental"] = child_payload
+        child_params.extra_args = extra_args
+
+    def _vllm_exp_add_hidden_logprobs(self, request: Request, new_logprobs: Any) -> None:
+        logprob_values = getattr(new_logprobs, "logprobs", None)
+        if logprob_values is None:
+            return
+        self._vllm_exp_hidden_scores[request.request_id] += float(
+            logprob_values[:, 0].sum()
+        )
+
+    def _vllm_exp_complete_hidden_child(self, child: Request) -> Request | None:
+        parent_id = self._vllm_exp_child_to_parent[child.request_id]
+        self._vllm_exp_branch_completed[parent_id].add(child.request_id)
+        child_ids = self._vllm_exp_branch_children[parent_id]
+        if len(self._vllm_exp_branch_completed[parent_id]) < len(child_ids):
+            return None
+
+        parent = self.requests[parent_id]
+        if self._vllm_exp_pending_branch_plans[parent_id]:
+            self._vllm_exp_launch_branch_wave(parent, first_wave=False)
