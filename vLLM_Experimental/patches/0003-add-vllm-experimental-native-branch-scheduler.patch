+    def _vllm_exp_payload(self, request: Request) -> dict[str, Any] | None:
+        params = request.sampling_params
+        extra_args = getattr(params, "extra_args", None)
+        if not isinstance(extra_args, dict):
+            return None
+        payload = extra_args.get("vllm_experimental")
+        return payload if isinstance(payload, dict) else None
+
+    def _vllm_exp_is_hidden(self, request: Request) -> bool:
+        return bool(getattr(request, "_vllm_exp_hidden_branch", False))
+
+    def _vllm_exp_native_enabled(self, request: Request) -> bool:
+        payload = self._vllm_exp_payload(request)
+        return bool(payload) and bool(payload.get("native_scheduler_kv_fork")) and (
+            payload.get("mode")
+            in {"eps_on_policy_diverse", "eps_off_policy_verbalized"}
+        )
+
+    def _vllm_exp_ends_at_boundary(self, request: Request) -> bool:
+        payload = self._vllm_exp_payload(request)
+        assert payload is not None
+        token_payload = payload.get("control_token_ids")
+        assert isinstance(token_payload, dict)
+        exec_close = int(token_payload["exec_close"])
+        return bool(request._output_token_ids) and (
+            request._output_token_ids[-1] == exec_close
+        )
+
+    def _vllm_exp_fire_boundary(self, request: Request) -> bool:
+        payload = self._vllm_exp_payload(request)
+        assert payload is not None
+        parent_id = request.request_id
+        boundary_index = self._vllm_exp_parent_boundary_counts[parent_id]
+        self._vllm_exp_parent_boundary_counts[parent_id] = boundary_index + 1
+        fire_rate = float(payload.get("fire_rate", 0.10))
+        seed = int(payload.get("seed", 1234))
+        raw = f"{parent_id}:{boundary_index}:{seed}".encode("utf-8")
+        sample = int.from_bytes(hashlib.sha256(raw).digest()[:8], "big") / 2**64
+        return sample < fire_rate
+
+    def _vllm_exp_try_start_branch(self, request: Request) -> bool:
+        if self._vllm_exp_is_hidden(request):
+            return False
+        if not self._vllm_exp_native_enabled(request):
+            return False
+        if not self._vllm_exp_ends_at_boundary(request):
+            return False
+        if not self._vllm_exp_fire_boundary(request):
+            return False
+        return self._vllm_exp_start_branches(request)
+
+    def _vllm_exp_start_branches(self, parent: Request) -> bool:
+        payload = self._vllm_exp_payload(parent)
+        assert payload is not None
+        assert self.vllm_config.speculative_config is None, "spec decode unsupported"
+        assert not parent.has_encoder_inputs, "multimodal native branches unsupported"
+        assert not self.is_encoder_decoder, "encoder-decoder native branches unsupported"
+        assert not parent.resumable, "resumable streaming native branches unsupported"
+        assert parent.sampling_params is not None
+        assert parent.request_id not in self._vllm_exp_branch_children
+
+        remaining_tokens = parent.max_tokens - parent.num_output_tokens
+        branch_budget = min(
+            self._vllm_exp_requested_branch_budget(parent, payload),
+            remaining_tokens,
+        )
+        if branch_budget <= 0:
+            self._vllm_exp_log_event(
+                parent,
+                "branch_skip_no_budget",
+                remaining_tokens=remaining_tokens,
+            )
+            return False
+
+        fork_tokens = parent.num_computed_tokens // self.block_size * self.block_size
+        if fork_tokens <= 0:
+            self._vllm_exp_log_event(
+                parent,
+                "branch_skip_no_full_block",
+                block_size=self.block_size,
+                num_computed_tokens=parent.num_computed_tokens,
+            )
+            return False
+        branch_plan = self._vllm_exp_branch_plan(parent, payload)
+        parent_id = parent.request_id
+        self._vllm_exp_branch_children[parent_id] = []
+        self._vllm_exp_pending_branch_plans[parent_id] = list(branch_plan)
+        self._vllm_exp_branch_budgets[parent_id] = branch_budget
+        self._vllm_exp_branch_stop_token_ids[
+            parent_id
+        ] = self._vllm_exp_child_stop_token_ids(parent, payload)
+        self._vllm_exp_branch_fork_tokens[parent_id] = fork_tokens
+        child_ids = self._vllm_exp_launch_branch_wave(parent, first_wave=True)
+        self._vllm_exp_log_event(
+            parent,
+            "branch_start",
+            branch_budget=branch_budget,
+            candidate_count=len(child_ids),
+            total_candidate_count=len(branch_plan),
+            child_ids=child_ids,
+            fork_tokens=fork_tokens,
+            pending_candidate_count=len(self._vllm_exp_pending_branch_plans[parent_id]),
+            num_computed_tokens=parent.num_computed_tokens,
+            output_tokens=parent.num_output_tokens,
+            shared_blocks=fork_tokens // self.block_size,
+        )
+        parent.status = RequestStatus.PREEMPTED
+        return True
