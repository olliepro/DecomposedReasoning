+    def _vllm_exp_return_child_ids(
+        self,
+        *,
+        parent: Request,
+        child_ids: list[str],
+        top_k_child_ids: list[str],
+    ) -> list[str]:
+        payload = self._vllm_exp_payload(parent)
+        assert payload is not None
+        branch_fanout = int(payload.get("branch_fanout", 1))
+        if branch_fanout <= 1:
+            return []
+        if payload.get("mode") == "eps_on_policy_diverse":
+            return top_k_child_ids[:branch_fanout]
+        assert payload.get("mode") == "eps_off_policy_verbalized"
+        return child_ids[:branch_fanout]
+
+    def _vllm_exp_branch_output_records(
+        self,
+        *,
+        parent: Request,
+        child_ids: list[str],
+        top_k_child_ids: list[str],
+    ) -> list[dict[str, Any]]:
+        top_k_ids = set(top_k_child_ids)
+        records: list[dict[str, Any]] = []
+        for index, child_id in enumerate(child_ids):
+            child = self.requests[child_id]
+            candidate_id = int(getattr(child, "_vllm_exp_candidate_id", index))
+            suffix = list(child.output_token_ids)
+            finish_reason = child.get_finished_reason()
+            records.append(
+                {
+                    "index": candidate_id,
+                    "candidate_id": candidate_id,
+                    "child_id": child_id,
+                    "finish_reason": (
+                        str(finish_reason) if finish_reason is not None else None
+                    ),
+                    "in_diverse_top_k": child_id in top_k_ids,
+                    "stop_reason": child.stop_reason,
+                    "suffix_token_ids": suffix,
+                    "token_ids": list(parent.output_token_ids) + suffix,
+                }
+            )
+        return records
+
