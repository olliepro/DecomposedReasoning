+    def _vllm_exp_branch_pressure_report(
+        self, request: Request, *, include_queued: bool
+    ) -> dict[str, int | str | bool]:
+        payload = self._vllm_exp_payload(request)
+        assert payload is not None
+        live_count = len(self._vllm_exp_active_branch_pools)
+        queued_count = len(self._vllm_exp_branch_pool_queue)
+        live_limit = int(payload.get("native_branch_max_live_pools", 2))
+        queued_limit = int(payload.get("native_branch_max_queued_pools", 8))
+        assert live_limit >= 0, "native_branch_max_live_pools must be non-negative"
+        assert queued_limit >= 0, "native_branch_max_queued_pools must be non-negative"
+        if live_limit > 0 and live_count >= live_limit:
+            reason = "live_pool_limit"
+        elif include_queued and queued_limit > 0 and queued_count >= queued_limit:
+            reason = "queued_pool_limit"
+        else:
+            reason = "admitted"
+        return {
+            "admissible": reason == "admitted",
+            "live_branch_pool_count": live_count,
+            "live_branch_pool_limit": live_limit,
+            "queued_branch_pool_count": queued_count,
+            "queued_branch_pool_limit": queued_limit,
+            "reason": reason,
+        }
