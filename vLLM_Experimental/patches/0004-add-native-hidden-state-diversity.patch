+    def _vllm_exp_needs_hidden_vector(self, req_id: str) -> bool:
+        request = self.requests.get(req_id)
+        if request is None or request.sampling_params is None:
+            return False
+        extra_args = getattr(request.sampling_params, "extra_args", None)
+        if not isinstance(extra_args, dict):
+            return False
+        payload = extra_args.get("vllm_experimental")
+        return isinstance(payload, dict) and bool(
+            payload.get("return_hidden_state_vector")
+        )
+
+    def _vllm_exp_hidden_vectors(
+        self,
+        *,
+        sample_hidden_states: torch.Tensor,
+        req_ids: list[str],
+        valid_sampled_token_ids: list[list[int]],
+        invalid_req_indices: list[int],
+    ) -> list[list[float] | None] | None:
+        tracked_indexes = [
+            index
+            for index, req_id in enumerate(req_ids)
+            if self._vllm_exp_needs_hidden_vector(req_id)
+        ]
+        if not tracked_indexes:
+            return None
+        assert sample_hidden_states.shape[0] >= len(req_ids)
+        hidden_vectors: list[list[float] | None] = [None] * len(req_ids)
+        invalid_index_set = set(invalid_req_indices)
+        for index in tracked_indexes:
+            if index in invalid_index_set:
+                continue
+            if not self.use_async_scheduling and (
+                index >= len(valid_sampled_token_ids)
+                or not valid_sampled_token_ids[index]
+            ):
+                continue
+            vector = sample_hidden_states[index].detach().to(
+                "cpu", dtype=torch.float32
+            )
+            norm = torch.linalg.vector_norm(vector)
+            if float(norm) == 0.0:
+                continue
+            hidden_vectors[index] = [
+                float(value) for value in (vector / norm).tolist()
+            ]
+        return hidden_vectors
+
